# ──────────────────────────────────────────────
#  TruRwanda – Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local for local development,
# or set these variables in your Vercel project dashboard.

# ─── Database (required) ────────────────────
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# ─── Payload CMS (required) ─────────────────
# A strong random string used to encrypt sessions and tokens
PAYLOAD_SECRET=your-strong-random-secret-here

# ─── Server URL (required for Vercel) ───────
# For local dev:  http://localhost:3000
# For Vercel:     https://your-app.vercel.app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Media Storage (recommended for Vercel) ─
# Optional: Vercel Blob Storage for persistent file uploads on Vercel.
# Without this, uploaded images will only work locally.
# Get a token at: https://vercel.com/dashboard/stores/blob
# BLOB_READ_WRITE_TOKEN=
