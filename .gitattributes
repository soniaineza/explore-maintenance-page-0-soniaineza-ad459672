# Auto-detect text files and normalize their line endings
* text=auto

# Shell scripts should always use LF line endings
*.sh text eol=lf

# Batch files should use CRLF line endings
*.bat text eol=crlf

# Binary files should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.woff2 binary
*.woff binary
*.eot binary
*.ttf binary
*.otf binary
*.zip binary
*.tar.gz binary
